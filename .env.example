# LLM Council - Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (default for all roles)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Per-Role API Keys (optional - to avoid rate limits)
# Set different keys for each role to distribute rate limit quotas
# Leave empty to use the default OPENROUTER_API_KEY
RESEARCHER_API_KEY=
CRITIC_API_KEY=
CREATIVE_THINKER_API_KEY=
PRACTICAL_ADVISOR_API_KEY=
VERIFIER_API_KEY=
CHAIRMAN_API_KEY=

# Application Settings (optional)
DEBUG=true
APP_NAME=LLM Council
APP_VERSION=1.0.0

# Request Settings (optional)
REQUEST_TIMEOUT=120
MAX_CONCURRENT_REQUESTS=6

# Deliberation Settings (optional)
MAX_DELIBERATION_ROUNDS=3
ENABLE_PEER_REVIEW=true
ENABLE_VERIFICATION=true
